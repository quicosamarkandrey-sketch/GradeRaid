{
  "name": "eduquest",
  "version": "1.0.0",
  "private": true,
  "description": "EduQuest — gamified classroom management app (vanilla JS + Supabase)",
  "scripts": {
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1"
  }
}
